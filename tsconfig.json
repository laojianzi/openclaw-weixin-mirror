{
  "compilerOptions": {
    "target": "ES2025",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "#/*": ["./scripts/*"]
    },
    "lib": ["ES2025"],
    "rootDir": "./scripts",
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUncheckedSideEffectImports": true,
    "types": ["bun-types", "node"]
  },
  "include": ["scripts/**/*.ts"]
}
